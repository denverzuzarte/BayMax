{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "50mb" }
    },
    {
      "src": "static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/static/(.*)", "dest": "/static/$1" },
    { "src": "/(.*)",        "dest": "/api/index.py" }
  ],
  "env": {
    "ANTHROPIC_API_KEY":    "@anthropic_api_key",
    "GOOGLE_PLACES_API_KEY": "@google_places_api_key"
  }
}
